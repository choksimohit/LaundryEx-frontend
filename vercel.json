{
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/about", "destination": "/", "permanent": true },
    { "source": "/pricing", "destination": "/order", "permanent": true },
    { "source": "/product/:slug*", "destination": "/order", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://laundry-ex.vercel.app/api/sitemap-xml"
    },
    {
      "source": "/zoho-domain-verification.html",
      "destination": "/zoho-domain-verification.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
